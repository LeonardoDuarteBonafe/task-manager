# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js / NextAuth
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_URL=http://localhost:3000

# Google OAuth (optional for local setup; required to enable Google sign in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu-email@exemplo.com
NOTIFICATIONS_JOB_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-the-same-or-another-long-random-secret

# Test credentials seed (optional)
TEST_USER_EMAIL=teste@taskmanager.local
TEST_USER_PASSWORD=Teste@123456
TEST_USER_NAME=Usuário de Teste

# Postgres (Supabase)
# Use the pooled connection string for runtime queries:
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
# Use direct connection for migrations and introspection:
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
